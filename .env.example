# OpenAI API 配置
# 请复制此文件为 .env，并填入您的真实 API Key
OPENAI_API_KEY=sk-your-api-key-here

# 可选：如果使用国内代理服务，修改 base-url
# OPENAI_BASE_URL=https://api.your-proxy.com/v1

# MySQL 数据库配置
MYSQL_ROOT_PASSWORD=root

# Redis 配置
REDIS_PASSWORD=

# Milvus 配置
MILVUS_USERNAME=root
MILVUS_PASSWORD=Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# MinIO 配置（Milvus 依赖 + 业务文档对象存储）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENABLED=true
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=power-trade-rag

# OCR 配置
RAG_OCR_ENABLED=false
RAG_OCR_PROVIDER=none
RAG_OCR_ENDPOINT=
RAG_OCR_API_KEY=
RAG_OCR_RESPONSE_FIELD=text
RAG_OCR_CONNECT_TIMEOUT_MS=3000
RAG_OCR_READ_TIMEOUT_MS=10000

# 摄取任务 Worker 配置
RAG_INGEST_WORKER_DELAY_MS=5000
